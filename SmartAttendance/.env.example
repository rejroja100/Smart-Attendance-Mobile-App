# Copy this file to .env and fill in real values.
# All EXPO_PUBLIC_* vars are bundled into the app at build time.

# Where the FastAPI backend is reachable from your phone.
# Use your PC's LAN IP (find with `ipconfig` on Windows). NOT localhost.
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:8000

# From Firebase Console -> Project settings -> "Your apps" -> Web app -> Web client ID.
# Looks like: 123456789-abcdefg.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
