rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isTeacher() {
      return isSignedIn() && userRole() == 'teacher';
    }

    function isStudent() {
      return isSignedIn() && userRole() == 'student';
    }

    // Users: each user can read/write their own profile.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwnUser(uid);
      allow delete: if false;
    }

    // Courses
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
      // Students can update only when enrolling themselves (server enforces specifics)
      allow update: if isStudent()
        && request.auth.uid in request.resource.data.studentIds;
    }

    // Attendance: read by owning student or teacher of the course; writes via backend.
    match /attendance/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // mutations go through the backend
    }

    // Codes: read by anyone signed in; writes only by the course's teacher.
    match /codes/{courseId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }

    // Bluetooth sessions
    match /bluetooth_sessions/{courseId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }
  }
}
